# MongoDB connection string - szerezd be: https://cloud.mongodb.com
# Példa: mongodb+srv://user:password@cluster.mongodb.net/erpsystem?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/erpsystem?retryWrites=true&w=majority

# MongoDB adatbázis neve (opcionális, alapértelmezett: erpsystem)
MONGODB_DB=erpsystem

# Seed engedélyezése production-ban (állítsuk 'allow'-ra egyszer, majd töröljük)
# SEED_SECRET=allow
